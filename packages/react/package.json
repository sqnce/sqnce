{
  "name": "@sqnce/react",
  "version": "0.1.0",
  "description": "Rolodex UI for sqnce workflows: focused active sub-stage, gated advancement, browseable history.",
  "type": "module",
  "main": "src/index.js",
  "types": "./types/index.d.ts",
  "exports": { ".": { "types": "./types/index.d.ts", "default": "./src/index.js" } },
  "files": ["src", "types"],
  "scripts": {
    "types": "tsc -p tsconfig.declarations.json",
    "prepack": "tsc -p ../core/tsconfig.declarations.json && npm run types"
  },
  "dependencies": { "@sqnce/core": "^0.1.0" },
  "peerDependencies": { "react": ">=18", "react-dom": ">=18" },
  "publishConfig": { "access": "public" },
  "keywords": ["workflow", "react", "rolodex", "stage-gate", "sqnce"],
  "license": "Apache-2.0",
  "homepage": "https://github.com/sqnce/sqnce#readme",
  "bugs": { "url": "https://github.com/sqnce/sqnce/issues" },
  "repository": { "type": "git", "url": "git+https://github.com/sqnce/sqnce.git", "directory": "packages/react" }
}
